# ============================================================
# ENV Template — Copy sang .env và điền API keys thật vào
# File .env KHÔNG được push lên GitHub
# ============================================================

# DeepSeek API (primary model)
# Lấy tại: https://platform.deepseek.com/
DEEPSEEK_KEY=your_deepseek_key_here

# Google Gemini API (fallback model)
# Lấy tại: https://aistudio.google.com/
GEMINI_KEY=your_gemini_key_here

# Anthropic Claude (optional legacy)
# ANTHROPIC_KEY=your_anthropic_key_here

# Trading Config
ACCOUNT_BALANCE=500
LEVERAGE=200
MONTHLY_TARGET_PCT=100
PROP_FIRM_MODE=true
